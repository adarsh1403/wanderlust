<% layout("/layouts/boilerplate") %>

<div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white border border-zinc-200 rounded-2xl shadow-sm p-8 w-full max-w-md">
        <h1 class="text-2xl font-bold text-zinc-900 mb-1">Sign Up</h1>
        <p class="text-sm text-zinc-500 mb-6">Join Driftr and discover extraordinary stays.</p>
        
        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-4">
                <label for="username" class="block text-sm font-medium text-zinc-700 mb-1.5">Username</label>
                <input type="text" id="username" name="username" class="w-full border border-zinc-300 rounded-lg px-3 py-2.5 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent" required>
                <div class="invalid-feedback text-sm text-red-600 mt-1">Please choose a username.</div>
            </div>
            
            <div class="mb-4">
                <label for="email" class="block text-sm font-medium text-zinc-700 mb-1.5">Email</label>
                <input type="email" id="email" name="email" class="w-full border border-zinc-300 rounded-lg px-3 py-2.5 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent" required>
                <div class="invalid-feedback text-sm text-red-600 mt-1">Please enter a valid email.</div>
            </div>
            
            <div class="mb-6">
                <label for="password" class="block text-sm font-medium text-zinc-700 mb-1.5">Password</label>
                <input type="password" id="password" name="password" minlength="6" class="w-full border border-zinc-300 rounded-lg px-3 py-2.5 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent" required>
                <div class="invalid-feedback text-sm text-red-600 mt-1">Password must be at least 6 characters.</div>
            </div>
            
            <button type="submit" class="w-full flex justify-center bg-orange-700 text-white hover:bg-orange-800 rounded-lg px-5 py-2.5 text-sm font-medium transition-colors mb-4">Sign Up</button>
        </form>
        
        <div class="text-center">
            <span class="text-sm text-zinc-600">Already have an account? <a href='/login' class="text-orange-700 hover:text-orange-900 font-medium transition-colors">Log in</a></span>
        </div>
    </div>
</div>