<% layout("layouts/boilerplate") -%>
  <script>
    let mapboxToken = "<%= process.env.MAPBOX_TOKEN %>";
    const coordinatesStr = "<%- JSON.stringify(listing.geometry.coordinates) %>";
  </script>

  <div class="max-w-6xl mx-auto py-6">
    <div class="mb-6">
      <h2 class="text-2xl font-bold text-zinc-900 mb-2"><%= listing.title %></h2>
      <p class="text-sm text-zinc-500 mb-3">Hosted by <%= listing.owner.username %></p>
    </div>

    <img src="<%= listing.image.url %>" alt="listing image" class="w-full h-80 object-cover rounded-xl mb-8 shadow-sm">

    <div class="lg:grid lg:grid-cols-3 gap-10">
      <!-- Left column: Details -->
      <div class="col-span-2">
        <div class="mb-8">
          <p class="text-sm text-zinc-700 mb-4 whitespace-pre-line"><%= listing.description %></p>
          <div class="flex items-center gap-2 text-sm text-zinc-700 mb-2">
            <i class="fa-solid fa-tag w-5 text-center"></i>
            <span class="font-semibold text-zinc-900">&#8377; <%= listing.price.toLocaleString("en-IN") %></span> / night
          </div>
          <div class="flex items-center gap-2 text-sm text-zinc-700 mb-2">
            <i class="fa-solid fa-location-dot w-5 text-center"></i>
            <span><%= listing.location %>, <%= listing.country %></span>
          </div>
        </div>

        <% if (currentUser && listing.owner._id.equals(currentUser._id)) { %>
          <div class="flex gap-3 mb-8 pt-6 border-t border-zinc-200">
            <a href="/listings/<%= listing._id %>/edit" class="bg-orange-700 text-white hover:bg-orange-800 rounded-lg px-5 py-2.5 text-sm font-medium transition-colors">Edit</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
              <button class="bg-zinc-900 text-white hover:bg-zinc-700 rounded-lg px-5 py-2.5 text-sm font-medium transition-colors">Delete</button>
            </form>
          </div>
        <% } %>

        <!-- Reviews list -->
        <div class="pt-8 border-t border-zinc-200">
          <h3 class="text-xl font-semibold text-zinc-900 mb-6">Reviews</h3>
          <% if (listing.reviews.length === 0) { %>
            <p class="text-sm text-zinc-500 bg-zinc-50 rounded-lg p-4 border border-zinc-100">No reviews yet. Be the first to review this listing!</p>
          <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <% listing.reviews.forEach(review => { %>
              <div class="bg-white border border-zinc-100 rounded-xl p-5 shadow-sm relative group">
                <div class="flex items-center justify-between mb-2">
                  <h5 class="text-sm font-semibold text-zinc-900"><%= review.author.username %></h5>
                  <% if (currentUser && review.author._id.equals(currentUser._id)) { %>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="m-0">
                      <button class="text-red-600 hover:text-red-800 text-xs font-medium underline opacity-0 group-hover:opacity-100 transition-opacity">Delete</button>
                    </form>
                  <% } %>
                </div>
                <p class="starability-result text-sm mb-2" data-rating="<%= review.rating %>"></p>
                <p class="text-sm text-zinc-700 mt-2"><%= review.comment %></p>
              </div>
            <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Right column: Review Form -->
      <div class="col-span-1 mt-10 lg:mt-0">
        <div class="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm mb-8 sticky top-24">
          <h4 class="text-lg font-semibold text-zinc-900 mb-4">Leave a review</h4>
          <% if (!currentUser) { %>
            <p class="text-sm text-zinc-600">Please <a href="/login" class="text-orange-700 hover:underline font-medium">log in</a> to leave a review.</p>
          <% } else { %>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
              <div class="mb-4">
                <fieldset class="starability-slot">
                  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" aria-label="No rating." />
                  <input type="radio" id="first-rate1" name="review[rating]" value="1" checked />
                  <label for="first-rate1" title="Terrible">1 star</label>
                  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                  <label for="first-rate2" title="Not good">2 stars</label>
                  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                  <label for="first-rate3" title="Average">3 stars</label>
                  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                  <label for="first-rate4" title="Very good">4 stars</label>
                  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                  <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
              </div>
              <div class="mb-4">
                <label for="comment" class="block text-sm font-medium text-zinc-700 mb-1.5">Comments</label>
                <textarea name="review[comment]" id="comment" rows="4" class="w-full border border-zinc-300 rounded-lg px-3 py-2.5 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent resize-none" placeholder="Share your experience" required></textarea>
                <div class="invalid-feedback text-sm text-red-600 mt-1">Please enter your comments.</div>
              </div>
              <button class="w-full bg-orange-700 text-white hover:bg-orange-800 rounded-lg px-5 py-2.5 text-sm font-medium transition-colors">Submit Review</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Map Section -->
    <div class="mt-12 pt-8 border-t border-zinc-200">
      <h3 class="text-xl font-semibold text-zinc-900 mb-4">Where you'll be</h3>
      <div id="map" class="w-full h-[300px] md:h-[400px] rounded-xl border border-zinc-200 shadow-sm z-0"></div>
    </div>
  </div>

  <script src="/js/map.js"></script>