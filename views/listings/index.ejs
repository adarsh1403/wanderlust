<% layout("layouts/boilerplate") -%>

<!-- Filters & Toggles -->
<div class="mb-8">
  <!-- Filter Chips -->
  <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-hide w-full mb-4 border-b border-zinc-100">
    <!-- Categories -->
    <% const currentCat = typeof category !== 'undefined' ? category : ''; %>
    <% const cats = [
      {name: "Apartments", icon: "fa-building"},
      {name: "Villas", icon: "fa-house"},
      {name: "Cabins", icon: "fa-house-chimney-window"},
      {name: "Beachfront", icon: "fa-umbrella-beach"},
      {name: "Castles", icon: "fa-fort-awesome"},
      {name: "Unique", icon: "fa-star"}
    ]; %>
    <% for(let c of cats) { %>
      <a href="/listings?category=<%= c.name %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border <%= currentCat === c.name ? 'bg-zinc-900 text-white border-zinc-900 shadow-sm' : 'bg-white border-zinc-200 text-zinc-700 hover:border-zinc-400 hover:bg-zinc-50' %> text-sm transition-all cursor-pointer whitespace-nowrap">
        <i class="fa-solid <%= c.icon %>"></i><span><%= c.name %></span>
      </a>
    <% } %>

    <div class="h-8 w-px bg-zinc-300 mx-1 self-center shrink-0"></div>

    <!-- Amenities -->
    <% const currentAmenity = typeof amenities !== 'undefined' ? amenities : ''; %>
    <% const amens = [
      {name: "WiFi", icon: "fa-wifi"},
      {name: "Pool", icon: "fa-person-swimming"},
      {name: "Hot Tub", icon: "fa-hot-tub-person"},
      {name: "Free Parking", icon: "fa-square-parking"},
      {name: "AC", icon: "fa-snowflake"},
      {name: "Kitchen", icon: "fa-kitchen-set"},
      {name: "Pet Friendly", icon: "fa-paw"},
      {name: "TV", icon: "fa-tv"},
      {name: "Washer", icon: "fa-shirt"}
    ]; %>
    <% for(let a of amens) { %>
      <a href="/listings?amenities=<%= a.name %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border <%= currentAmenity === a.name ? 'bg-orange-600 text-white border-orange-600 shadow-sm' : 'bg-white border-zinc-200 text-zinc-700 hover:border-zinc-400 hover:bg-zinc-50' %> text-sm transition-all cursor-pointer whitespace-nowrap">
        <i class="fa-solid <%= a.icon %>"></i><span><%= a.name %></span>
      </a>
    <% } %>
  </div>

  <!-- Tax Toggle Row -->
  <div class="flex justify-end items-center mt-2">
    <div class="flex items-center bg-white border border-zinc-200 rounded-xl px-5 py-3 transition-colors hover:border-zinc-300">
      <label class="flex items-center cursor-pointer gap-4 m-0">
        <div class="flex items-center gap-3">
          <span class="text-[15px] font-medium text-zinc-800">Display total price</span>
          <span class="text-zinc-300 text-sm">|</span>
          <span class="text-[15px] text-zinc-500">Includes all fees, before taxes</span>
        </div>
        <div class="relative ml-4 shrink-0">
          <input type="checkbox" id="flexSwitchCheckDefault" class="sr-only peer">
          <div class="w-12 h-7 bg-zinc-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-5 peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-zinc-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-orange-600"></div>
        </div>
      </label>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
  <% for(let listing of allListings) { %>
    <div class="bg-white rounded-xl overflow-hidden border border-zinc-100 shadow-sm hover:shadow-md transition-all duration-200 h-full flex flex-col relative group">
      <a href="/listings/<%= listing._id %>" class="flex-1 flex flex-col">
        <div class="overflow-hidden relative">
          <img src="<%= listing.image.url %>" alt="image" class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300">
          <% if (listing.isAvailable === false) { %>
            <div class="absolute top-3 left-3 bg-zinc-900/90 text-white text-xs font-semibold px-3 py-1.5 rounded-lg backdrop-blur-sm shadow-sm z-10">
              Not Available
            </div>
          <% } %>
        </div>
        <div class="p-4 flex-1 flex flex-col">
          <div class="flex justify-between items-start gap-2 mb-1">
            <h3 class="text-sm font-semibold text-zinc-900 line-clamp-1"><%= listing.title %></h3>
            <% if (listing.avgRating > 0) { %>
              <div class="flex items-center gap-1 text-sm font-semibold text-zinc-900 shrink-0">
                <i class="fa-solid fa-star text-xs"></i>
                <span><%= listing.avgRating %></span>
              </div>
            <% } else { %>
              <div class="text-xs text-zinc-500 shrink-0 mt-0.5">New</div>
            <% } %>
          </div>
          <p class="text-sm text-zinc-600 mt-auto">
            <span class="font-semibold text-zinc-900">&#8377; <%= listing.price.toLocaleString("en-IN") %></span> / night
            <i class="tax-info text-xs text-zinc-500" style="display: none;">&nbsp;+18% GST</i>
          </p>
        </div>
      </a>
      
      <% if (currentUser) { %>
          <% const isSaved = currentUser.savedListings && currentUser.savedListings.some(id => id.equals(listing._id)) %>
          <form action="/listings/<%= listing._id %>/save" method="POST" class="absolute top-3 right-3 z-10 m-0">
              <button type="submit" class="bg-transparent border-none p-1 transition-transform hover:scale-110 active:scale-95 focus:outline-none cursor-pointer">
                  <% if (isSaved) { %>
                      <i class="fa-solid fa-heart text-orange-600 text-2xl drop-shadow-md"></i> 
                  <% } else { %>
                      <i class="fa-regular fa-heart text-white text-2xl drop-shadow-[0_0_3px_rgba(0,0,0,0.5)]"></i> 
                  <% } %>
              </button>
          </form>
      <% } %>
    </div>
  <% } %>
</div>

<% if (totalPages > 1) { %>
  <div class="flex justify-center mt-12 mb-8">
    <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
      
      <!-- Previous -->
      <% if (currentPage === 1) { %>
        <span class="relative inline-flex items-center px-4 py-2 rounded-l-md border border-zinc-300 bg-zinc-50 text-sm font-medium text-zinc-400 cursor-not-allowed">
          Previous
        </span>
      <% } else { %>
        <a href="/listings?page=<%= currentPage - 1 %><%= typeof q !== 'undefined' && q ? '&q=' + q : '' %><%= typeof category !== 'undefined' && category ? '&category=' + category : '' %><%= typeof amenities !== 'undefined' && amenities ? '&amenities=' + amenities : '' %>" class="relative inline-flex items-center px-4 py-2 rounded-l-md border border-zinc-300 bg-white text-sm font-medium text-zinc-700 hover:bg-zinc-50">
          Previous
        </a>
      <% } %>

      <!-- Pages -->
      <% for(let i = 1; i <= totalPages; i++) { %>
        <% if (currentPage === i) { %>
          <span class="relative inline-flex items-center px-4 py-2 border border-orange-600 bg-orange-50 text-sm font-medium text-orange-600 z-10">
            <%= i %>
          </span>
        <% } else { %>
          <a href="/listings?page=<%= i %><%= typeof q !== 'undefined' && q ? '&q=' + q : '' %><%= typeof category !== 'undefined' && category ? '&category=' + category : '' %><%= typeof amenities !== 'undefined' && amenities ? '&amenities=' + amenities : '' %>" class="relative inline-flex items-center px-4 py-2 border border-zinc-300 bg-white text-sm font-medium text-zinc-700 hover:bg-zinc-50">
            <%= i %>
          </a>
        <% } %>
      <% } %>

      <!-- Next -->
      <% if (currentPage === totalPages) { %>
        <span class="relative inline-flex items-center px-4 py-2 rounded-r-md border border-zinc-300 bg-zinc-50 text-sm font-medium text-zinc-400 cursor-not-allowed">
          Next
        </span>
      <% } else { %>
        <a href="/listings?page=<%= currentPage + 1 %><%= typeof q !== 'undefined' && q ? '&q=' + q : '' %><%= typeof category !== 'undefined' && category ? '&category=' + category : '' %><%= typeof amenities !== 'undefined' && amenities ? '&amenities=' + amenities : '' %>" class="relative inline-flex items-center px-4 py-2 rounded-r-md border border-zinc-300 bg-white text-sm font-medium text-zinc-700 hover:bg-zinc-50">
          Next
        </a>
      <% } %>

    </nav>
  </div>
<% } %>

<script>
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");
  taxSwitch.addEventListener("change", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(let info of taxInfo) {
      if(info.style.display !== "inline") {
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>