<!-- template for showing all the listings  -->
<!-- uses bootstrap grid and card layout for resposive design -->
<% layout("layouts/boilerplate") -%>

  <h3 class="mb-4">All Listings</h3>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-card-link text-decoration-none">
          <div class="card listing-card h-100">
            <img src="<%= listing.image.url %>" class="card-img-top listing-card-img" alt="image">
            <div class="card-body">
              <p class="card-text mb-0"><b>
                  <%= listing.title %>
                </b><br>&#8377; <%= listing.price.toLocaleString("en-IN") %>
              </p>
            </div>
          </div>
        </a>
      </div>
      <% } %>
  </div>