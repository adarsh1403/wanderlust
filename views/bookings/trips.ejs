<% layout("layouts/boilerplate") -%>

<div class="max-w-6xl mx-auto py-8">
  <h2 class="text-3xl font-bold text-zinc-900 mb-2">My Trips</h2>
  <p class="text-zinc-600 mb-8">View all your upcoming and past reservations.</p>

  <% if (bookings.length === 0) { %>
    <div class="bg-zinc-50 border border-zinc-200 rounded-xl p-8 text-center">
      <i class="fa-solid fa-suitcase-rolling text-4xl text-zinc-400 mb-4"></i>
      <h3 class="text-xl font-semibold text-zinc-900 mb-2">No trips booked... yet!</h3>
      <p class="text-zinc-500 mb-6">Time to dust off your bags and start planning your next adventure.</p>
      <a href="/listings" class="inline-block bg-orange-700 text-white hover:bg-orange-800 rounded-lg px-6 py-3 font-medium transition-colors">Start Exploring</a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% bookings.forEach(booking => { %>
        <div class="bg-white border border-zinc-200 rounded-xl overflow-hidden shadow-sm flex flex-col group">
          <div class="relative h-48 overflow-hidden">
            <img src="<%= booking.listing.image.url %>" alt="Listing Image" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105">
            <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-full text-xs font-semibold text-zinc-900 shadow-sm">
              <%= booking.checkIn > new Date() ? 'Upcoming' : 'Completed' %>
            </div>
          </div>
          
          <div class="p-5 flex-1 flex flex-col">
            <div class="flex justify-between items-start mb-2">
              <h3 class="font-bold text-lg text-zinc-900 line-clamp-1"><%= booking.listing.title %></h3>
            </div>
            
            <p class="text-sm text-zinc-600 mb-4"><%= booking.listing.location %>, <%= booking.listing.country %></p>
            
            <div class="mt-auto pt-4 border-t border-zinc-100 flex flex-col gap-2">
              <div class="flex justify-between text-sm text-zinc-700">
                <span class="font-medium">Dates:</span>
                <span><%= booking.checkIn.toLocaleDateString('en-GB') %> - <%= booking.checkOut.toLocaleDateString('en-GB') %></span>
              </div>
              <div class="flex justify-between text-sm text-zinc-700">
                <span class="font-medium">Total Paid:</span>
                <span class="font-bold text-zinc-900">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
              </div>
            </div>
          </div>
          <a href="/listings/<%= booking.listing._id %>" class="block w-full bg-zinc-50 text-zinc-700 text-center py-3 text-sm font-medium hover:bg-zinc-100 transition-colors border-t border-zinc-200">View Listing</a>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
