<% if (typeof success !=='undefined' && success.length> 0) { %>
    <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm mb-4 flex justify-between items-start shadow-sm"
        role="alert" data-flash>
        <div>
            <%= success %>
        </div>
        <button type="button" class="text-green-600 hover:text-green-900 ml-3" data-flash-close>
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <% } %>

        <% if (typeof error !=='undefined' && error.length> 0) { %>
            <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm mb-4 flex justify-between items-start shadow-sm"
                role="alert" data-flash>
                <div>
                    <%= error %>
                </div>
                <button type="button" class="text-red-600 hover:text-red-900 ml-3" data-flash-close>
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <% } %>