<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driftr</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <link rel="stylesheet" href="/css/rating.css">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.21.0/mapbox-gl.css" rel="stylesheet">
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.21.0/mapbox-gl.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Inter', 'sans-serif'] },
            colors: { accent: '#C2410C' }
          }
        }
      }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .invalid-feedback { display: none; }
        .was-validated :invalid ~ .invalid-feedback,
        .was-validated :invalid ~ div .invalid-feedback { display: block; }
        .was-validated :invalid { border-color: #dc2626; }
    </style>
</head>
<body class="font-sans bg-white text-zinc-900 flex flex-col min-h-screen">
    <%- include("../includes/navbar") %>
    <main class="flex-1 container mx-auto px-4 my-8 max-w-7xl">
        <%- include("../includes/flash") %>
        <%- body %>
    </main>
    <%- include("../includes/footer") %>
    <script src="/js/script.js"></script>
</body>
</html>