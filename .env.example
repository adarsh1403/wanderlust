# Cloudinary — image hosting
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# Mapbox — geocoding & map rendering (public token, pk.*)
MAPBOX_TOKEN=your_mapbox_public_token

# MongoDB Atlas — database connection string
ATLASDB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_NAME=driftr

# Seed script — existing User ObjectId to assign as listing owner
SEED_OWNER_ID=replace_with_existing_user_object_id

# Session — use a long, random string (e.g. output of: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SECRET=replace_with_a_strong_random_string
